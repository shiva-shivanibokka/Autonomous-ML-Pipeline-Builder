# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# At least one provider key is required. Anthropic is the default.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── E2B Sandbox ───────────────────────────────────────────────────────────────
# Required for cloud sandbox execution. Get a key at https://e2b.dev
# If not set, falls back to local subprocess execution (less secure).
E2B_API_KEY=e2b_...

# ── MLflow ────────────────────────────────────────────────────────────────────
# Local file store by default (offline-safe, no server needed). Use the docker
# stack's server with: http://localhost:5001
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=autonomous-ml-pipeline

# ── Pipeline Settings ─────────────────────────────────────────────────────────
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-3-5-sonnet-20241022
EXECUTION_BACKEND=e2b           # "e2b" (safe, recommended) or "subprocess"
MAX_CORRECTION_RETRIES=3
SANDBOX_TIMEOUT_SECONDS=120

# Host execution of LLM-generated code is UNSAFE and disabled by default.
# Enable ONLY for local development (never on a public deployment).
ALLOW_LOCAL_EXEC=false

# ── Deployment / Security ─────────────────────────────────────────────────────
APP_ENV=development              # "development" or "production"
# In production this MUST be an explicit allowlist (your Vercel URL), not "*".
ALLOWED_ORIGINS=*
MAX_UPLOAD_MB=50

# ── Service Ports ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
GRADIO_PORT=7860
